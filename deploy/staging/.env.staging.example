APP_ENV=staging
APP_NAME=roadie-api
API_V1_PREFIX=/api/v1
WS_V1_PREFIX=/ws/v1
LOG_LEVEL=INFO
SQL_ECHO=false
DEMO_MODE=false
CORS_ORIGINS=http://localhost:5173

BACKEND_IMAGE=ghcr.io/owner/repository-backend
BACKEND_IMAGE_TAG=staging

MYSQL_DATABASE=roadie
MYSQL_USER=roadie
MYSQL_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME
DATABASE_URL=mysql+asyncmy://roadie:CHANGE_ME@mysql:3306/roadie?charset=utf8mb4

DEFAULT_ADMIN_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_ADMIN_EMAIL=admin@example.com

MODEL_PATH=/app/artifacts/models/best_ViT_kaggle_rgb2_4cls.pth
MODEL_VERSION=vit-dms-1.0.0
DRIVER_MONITORING_ADAPTER=MOCK
MOCK_VIT_INFERENCE_LATENCY_MS=0
POLICY_VERSION=risk-policy-1.0.0
WS_RECOMMENDED_FRAME_FPS=5
WS_LOCATION_INTERVAL_MS=1000
WS_HEARTBEAT_INTERVAL_MS=10000
WS_HEARTBEAT_TIMEOUT_MS=30000

GEMINI_API_KEY=
GEMINI_MODEL=
EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

REPORT_STORAGE_PATH=/app/storage/reports

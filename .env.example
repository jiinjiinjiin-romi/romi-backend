APP_ENV=development
APP_NAME=roadie-api
API_V1_PREFIX=/api/v1
WS_V1_PREFIX=/ws/v1
LOG_LEVEL=INFO
SQL_ECHO=false
DEMO_MODE=true
CORS_ORIGINS=http://localhost:5173

BACKEND_EXPOSED_PORT=8000

TMAP_APP_KEY=
TMAP_REQUEST_TIMEOUT_SECONDS=10
TMAP_PROXY_CACHE_TTL_MS=30000

CLOVA_VOICE_CLIENT_ID=
CLOVA_VOICE_CLIENT_SECRET=
CLOVA_VOICE_TTS_URL=https://naveropenapi.apigw.ntruss.com/tts-premium/v1/tts
CLOVA_VOICE_REQUEST_TIMEOUT_SECONDS=10
CLOVA_VOICE_ASSISTANT_SPEAKER=nara
CLOVA_VOICE_USER_MALE_SPEAKER=nminsang
CLOVA_VOICE_USER_FEMALE_SPEAKER=nminseo

MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=roadie
MYSQL_USER=driving_user
MYSQL_PASSWORD=change-me-driving
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_EXPOSED_PORT=3306

DEFAULT_ADMIN_ACCOUNT_ID=00000000-0000-0000-0000-000000000001
DEFAULT_ADMIN_EMAIL=admin@example.com

MODEL_PATH=/app/artifacts/models/best_vit.pth
MODEL_VERSION=vit-dms-1.0.0
DRIVER_MONITORING_ADAPTER=MOCK
MOCK_VIT_INFERENCE_LATENCY_MS=0
POLICY_VERSION=risk-policy-1.0.0
WS_RECOMMENDED_FRAME_FPS=5
WS_LOCATION_INTERVAL_MS=1000
WS_LOCATION_PERSIST_INTERVAL_MS=5000
WS_HEARTBEAT_INTERVAL_MS=10000
WS_HEARTBEAT_TIMEOUT_MS=30000
WS_FRAME_BINARY_TIMEOUT_MS=1000
WS_MAX_FRAME_BYTES=307200
WS_FRAME_QUEUE_MAX_SIZE=2
WS_FRAME_RECENT_ID_CACHE_SIZE=256
WS_FRAME_MAX_WIDTH=1920
WS_FRAME_MAX_HEIGHT=1080
DRIVING_MOVING_SPEED_THRESHOLD_KPH=5.0
DRIVING_LOCATION_MAX_ACCURACY_METERS=100.0

GEMINI_API_KEY=
GEMINI_MODEL=
GEMINI_BEHAVIOR_SENSITIVITY_PROMPT="Gemini에 전달할 운전 위험 민감도 분석 프롬프트를 입력하세요. 다른 설명, Markdown 코드 펜스, 추가 키 없이 아래와 정확히 같은 구조의 유효한 JSON 객체만 반환하도록 지시하세요. 각 값은 3부터 10 사이의 정수여야 합니다: {\"behaviorWarningSensitivity\":{\"DROWSINESS\":8,\"PHONE_USE\":8,\"FOOD_OR_DRINK\":8,\"GAZE_AWAY\":8,\"SECONDARY_TASK\":8,\"REACHING_BEHIND\":8,\"SMOKING\":8}}"
GEMINI_REQUEST_TIMEOUT_SECONDS=45

EMAIL_PROVIDER=
EMAIL_HOST=
EMAIL_PORT=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=

REPORT_STORAGE_PATH=/app/storage/reports
